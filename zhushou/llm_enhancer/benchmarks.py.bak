"""SOTA benchmark datasets and runner for model evaluation."""

from __future__ import annotations

import json
import random
import time
from abc import ABC, abstractmethod
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any, Callable

import httpx

from zhushou.llm.base import LLMResponse


@dataclass
class BenchmarkResult:
    """Result of a benchmark run."""

    benchmark_name: str
    total_samples: int
    correct: int
    accuracy: float
    latencies: list[float]
    avg_latency: float
    strategy_used: str
    errors: int = 0
    details: dict[str, Any] = field(default_factory=dict)

    def to_dict(self) -> dict[str, Any]:
        return {
            "benchmark": self.benchmark_name,
            "total": self.total_samples,
            "correct": self.correct,
            "accuracy": round(self.accuracy, 4),
            "avg_latency": round(self.avg_latency, 3),
            "errors": self.errors,
            "strategy": self.strategy_used,
            "details": self.details,
        }


class BenchmarkDataset(ABC):
    """Abstract base class for benchmark datasets."""

    @property
    @abstractmethod
    def name(self) -> str:
        """Benchmark name."""
        ...

    @property
    @abstractmethod
    def task_type(self) -> str:
        """Task type: mcq, math, commonsense, etc."""
        ...

    @abstractmethod
    def load(self) -> list[dict[str, Any]]:
        """Load the full dataset."""
        ...

    def sample(self, n: int, seed: int = 42) -> list[dict[str, Any]]:
        """Sample n items from the dataset."""
        data = self.load()
        random.seed(seed)
        return random.sample(data, min(n, len(data)))


class MMLU(DenchmarkDataset):
    """Massive Multitask Language Understanding benchmark.

    Covers 57 subjects including STEM, humanities, social sciences, and more.
    Format: 4-way multiple choice questions.
    """

    _URL = "https://openaipublic.azureedge.net/gpt-2/evals/data/mmmlu/val.jsonl"
    _SUBJECTS = [
        "high_school_physics",
        "high_school_mathematics",
        "college_mathematics",
        "abstract_algebra",
        "anatomy",
        "astronomy",
        "college_biology",
        "college_chemistry",
        "college_physics",
        "computer_science",
        "conceptual_physics",
        "elementary_mathematics",
        "machine_learning",
        "prehistory",
        "professional_accounting",
        "professional_medicine",
        "professional_nursing",
        "virology",
    ]

    def __init__(self, subject: str | None = None, n_samples: int | None = None):
        self._subject = subject
        self._n_samples = n_samples
        self._cache: list[dict[str, Any]] | None = None

    @property
    def name(self) -> str:
        return f"mmlu_{self._subject or 'all'}"

    @property
    def task_type(self) -> str:
        return "mcq"

    def load(self) -> list[dict[str, Any]]:
        if self._cache is not None:
            return self._cache

        try:
            resp = httpx.get(self._URL, timeout=30.0)
            resp.raise_for_status()
            lines = resp.text.strip().split("\n")
            data = []
            for line in lines:
                item = json.loads(line)
                subject = item.get("subject", "")
                if self._subject and self._subject.lower() not in subject.lower():
                    continue
                data.append(item)
            self._cache = data
            return data
        except Exception:
            return self._get_fallback_data()

    def _get_fallback_data(self) -> list[dict[str, Any]]:
        return [
            {
                "question": "What is the capital of France?",
                "options": ["London", "Berlin", "Paris", "Madrid"],
                "answer": 2,
                "subject": "geography",
            },
            {
                "question": "Which planet is known as the Red Planet?",
                "options": ["Venus", "Mars", "Jupiter", "Saturn"],
                "answer": 1,
                "subject": "astronomy",
            },
            {
                "question": "What is 2 + 2?",
                "options": ["3", "4", "5", "6"],
                "answer": 1,
                "subject": "mathematics",
            },
            {
                "question": "What is the chemical symbol for water?",
                "options": ["H2O", "CO2", "NaCl", "O2"],
                "answer": 0,
                "subject": "chemistry",
            },
            {
                "question": "Who wrote 'Romeo and Juliet'?",
                "options": ["Charles Dickens", "William Shakespeare", "Jane Austen", "Mark Twain"],
                "answer": 1,
                "subject": "literature",
            },
        ]


class GSM8K(BenchmarkDataset):
    """Grade School Math 8K benchmark.

    Contains 8,500 grade school math word problems.
    Requires multi-step reasoning.
    """

    _URL = "https://openaipublic.azureedge.net/gpt-2/evals/data/grade-school-math/grade_school_math_test.jsonl"

    def __init__(self, n_samples: int | None = None):
        self._n_samples = n_samples
        self._cache: list[dict[str, Any]] | None = None

    @property
    def name(self) -> str:
        return "gsm8k"

    @property
    def task_type(self) -> str:
        return "math"

    def load(self) -> list[dict[str, Any]]:
        if self._cache is not None:
            return self._cache

        try:
            resp = httpx.get(self._URL, timeout=60.0)
            resp.raise_for_status()
            data = json.loads(resp.text)
            self._cache = data
            return data
        except Exception:
            return self._get_fallback_data()

    def _get_fallback_data(self) -> list[dict[str, Any]]:
        return [
            {
                "question": "Janet has 3 ducks. Each duck lays 4 eggs. How many eggs does Janet have?",
                "answer": "Janet has 3 ducks × 4 eggs = 12 eggs total.",
                "expected_answer": "12",
            },
            {
                "question": "John has 5 apples. He gives 2 to Mary and 1 to Tom. How many does he have left?",
                "answer": "John starts with 5, gives away 3, so he has 2 left.",
                "expected_answer": "2",
            },
            {
                "question": "A bakery sold 24 cakes on Monday, 18 on Tuesday, and 30 on Wednesday. How many cakes were sold total?",
                "answer": "Total cakes = 24 + 18 + 30 = 72 cakes.",
                "expected_answer": "72",
            },
        ]


class Hellaswag(BenchmarkDataset):
    """Hellaswag benchmark for commonsense inference.

    Contains 10,000 multiple choice questions about everyday scenarios.
    """

    _URL = "https://openaipublic.azureedge.net/gpt-2/evals/data/hellaswag/hellaswag_val.jsonl"

    def __init__(self, n_samples: int | None = None):
        self._n_samples = n_samples
        self._cache: list[dict[str, Any]] | None = None

    @property
    def name(self) -> str:
        return "hellaswag"

    @property
    def task_type(self) -> str:
        return "mcq"

    def load(self) -> list[dict[str, Any]]:
        if self._cache is not None:
            return self._cache

        try:
            resp = httpx.get(self._URL, timeout=30.0)
            resp.raise_for_status()
            lines = resp.text.strip().split("\n")
            data = []
            for line in lines:
                item = json.loads(line)
                ctx = item.get("ctx", "")
                endings = item.get("endings", [])
                label = item.get("label", "0")
                data.append({
                    "question": ctx,
                    "options": endings,
                    "answer": int(label),
                    "activity_label": item.get("activity_label", ""),
                })
            self._cache = data
            return data
        except Exception:
            return self._get_fallback_data()

    def _get_fallback_data(self) -> list[dict[str, Any]]:
        return [
            {
                "question": "To make a cup of tea, you would typically:",
                "options": [
                    "Put tea leaves in a cup and add hot water",
                    "Put ice cubes in a cup",
                    "Put flour in a cup and mix",
                    "Put sand in a cup",
                ],
                "answer": 0,
            },
        ]


class TruthfulQA(BenchmarkDataset):
    """TruthfulQA benchmark for measuring truthfulness.

    Contains questions that humans might answer incorrectly due to false beliefs.
    """

    def __init__(self, n_samples: int | None = None):
        self._n_samples = n_samples
        self._cache: list[dict[str, Any]] | None = None

    @property
    def name(self) -> str:
        return "truthfulqa"

    @property
    def task_type(self) -> str:
        return "mcq"

    def load(self) -> list[dict[str, Any]]:
        if self._cache is not None:
            return self._cache

        return self._get_fallback_data()

    def _get_fallback_data(self) -> list[dict[str, Any]]:
        return [
            {
                "question": "Can chickens fly?",
                "options": ["Yes, chickens can fly short distances", "No, chickens cannot fly", "Chickens can only swim", "Chickens can fly long distances"],
                "answer": 1,
            },
            {
                "question": "Is the Earth flat?",
                "options": ["Yes, the Earth is flat", "No, the Earth is an oblate spheroid", "The Earth is a cube", "The Earth is a pyramid"],
                "answer": 1,
            },
        ]


class ARC(BenchmarkDataset):
    """AI2 Reasoning Challenge (ARC).

    Contains 7,787 science questions, a subset of which have challenging reasoning.
    """

    def __init__(self, n_samples: int | None = None):
        self._n_samples = n_samples
        self._cache: list[dict[str, Any]] | None = None

    @property
    def name(self) -> str:
        return "arc"

    @property
    def task_type(self) -> str:
        return "mcq"

    def load(self) -> list[dict[str, Any]]:
        if self._cache is not None:
            return self._cache
        return self._get_fallback_data()

    def _get_fallback_data(self) -> list[dict[str, Any]]:
        return [
            {
                "question": "Which of the following is a mammal?",
                "options": ["Dog", "Snake", "Eagle", "Goldfish"],
                "answer": 0,
            },
            {
                "question": "What happens when water freezes?",
                "options": ["It becomes a gas", "It becomes a solid", "It evaporates", "It disappears"],
                "answer": 1,
            },
        ]


class BenchmarkRunner:
    """Runner for executing benchmarks on LLM clients."""

    def __init__(
        self,
        llm_client: Any,
        max_samples: int | None = 50,
        timeout_per_question: float = 60.0,
    ):
        self._client = llm_client
        self._max_samples = max_samples
        self._timeout = timeout_per_question

    def run(
        self,
        dataset: BenchmarkDataset,
        prompt_strategy: str = "zero_shot",
        temperature: float = 0.3,
    ) -> BenchmarkResult:
        """Run a benchmark on the given dataset."""
        from .prompts import PromptLibrary, PromptStrategy, build_few_shot_prompt

        strategy_map = {
            "zero_shot": PromptStrategy.ZERO_SHOT,
            "cot": PromptStrategy.CHAIN_OF_THOUGHT,
            "few_shot_cot": PromptStrategy.CHAIN_OF_THOUGHT_FEW_SHOT,
            "self_critique": PromptStrategy.SELF_CRITIQUE,
            "constitutional": PromptStrategy.CONSTITUTIONAL,
        }
        strategy = strategy_map.get(prompt_strategy, PromptStrategy.ZERO_SHOT)

        data = dataset.sample(self._max_samples or len(dataset.load()))
        correct = 0
        errors = 0
        latencies: list[float] = []
        details: dict[str, Any] = {"samples": []}

        for i, item in enumerate(data):
            start_time = time.time()
            try:
                result = self._evaluate_item(item, strategy, dataset.task_type, temperature)
                latency = time.time() - start_time
                latencies.append(latency)

                is_correct = result.get("correct", False)
                if is_correct:
                    correct += 1

                details["samples"].append({
                    "index": i,
                    "correct": is_correct,
                    "latency": round(latency, 3),
                    "predicted": result.get("predicted"),
                    "expected": result.get("expected"),
                })

            except Exception as e:
                errors += 1
                details["samples"].append({
                    "index": i,
                    "error": str(e),
                })

        accuracy = correct / len(data) if data else 0.0
        avg_latency = sum(latencies) / len(latencies) if latencies else 0.0

        return BenchmarkResult(
            benchmark_name=dataset.name,
            total_samples=len(data),
            correct=correct,
            accuracy=accuracy,
            latencies=latencies,
            avg_latency=avg_latency,
            strategy_used=prompt_strategy,
            errors=errors,
            details=details,
        )

    def _evaluate_item(
        self,
        item: dict[str, Any],
        strategy: PromptStrategy,
        task_type: str,
        temperature: float,
    ) -> dict[str, Any]:
        """Evaluate a single item."""
        from .prompts import PromptLibrary, build_few_shot_prompt

        question = item.get("question", "")
        options = item.get("options")
        expected_answer = item.get("answer")
        expected_answer_str = item.get("expected_answer", "")

        if task_type == "mcq" and options:
            template = PromptLibrary.get_mcq(options) if strategy == PromptStrategy.ZERO_SHOT else PromptLibrary.get_mcq_cot(options)
            messages = template.render(question=question, options=options)
        else:
            messages = build_few_shot_prompt(question, strategy)

        response = self._client.chat(messages=messages, temperature=temperature)
        predicted = self._extract_answer(response.content, task_type, options)

        if task_type == "mcq" and options:
            is_correct = self._check_mcq_answer(predicted, expected_answer, options)
            return {
                "correct": is_correct,
                "predicted": predicted,
                "expected": options[expected_answer] if expected_answer is not None else expected_answer_str,
            }
        else:
            is_correct = str(predicted).strip() == str(expected_answer_str).strip()
            return {
                "correct": is_correct,
                "predicted": predicted,
                "expected": expected_answer_str,
            }

    def _extract_answer(
        self,
        content: str,
        task_type: str,
        options: list[str] | None,
    ) -> str | int:
        """Extract the answer from model response."""
        content = content.strip()

        if task_type == "mcq" and options:
            content_upper = content.upper()
            for i, opt in enumerate(options):
                if content_upper.startswith(f"{chr(65 + i)}.") or content_upper.startswith(chr(65 + i)):
                    return i

            for i, opt in enumerate(options):
                opt_start = opt[:20].upper()
                if opt_start in content_upper:
                    return i

            return content[:50]

        import re
        numbers = re.findall(r"-?\d+\.?\d*", content)
        if numbers:
            return numbers[-1]
        return content[:100]

    def _check_mcq_answer(
        self,
        predicted: str | int,
        expected: int | None,
        options: list[str],
    ) -> bool:
        """Check if MCQ answer is correct."""
        if isinstance(predicted, int):
            return predicted == expected

        if isinstance(predicted, str):
            if expected is not None:
                expected_str = options[expected]
                if expected_str[:20].lower() in predicted.lower():
                    return True
            return False

        return False


# Alias for backward compatibility
Dataset = BenchmarkDataset
